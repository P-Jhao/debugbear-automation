# ------------------------------
# DebugBear API 凭证
# ------------------------------
# 必填：在 DebugBear 账号设置中创建
DEBUGBEAR_API_KEY=your_debugbear_api_key

# 可选：一般保持默认，除非你要覆盖 API 地址
DEBUGBEAR_API_BASE_URL=https://www.debugbear.com/api/v1

# 可选：admin/project（部分项目管理 API 需要 admin）
DEBUGBEAR_API_KEY_TYPE=admin

# 二选一：
# 1) 固定页面模式：设置 DEBUGBEAR_PAGE_ID
# 2) 自动建页模式：设置 DEBUGBEAR_PROJECT_ID（提交任务时会在项目中查找或创建页面）
DEBUGBEAR_PROJECT_ID=
DEBUGBEAR_PAGE_ID=

# ------------------------------
# 批量测试默认配置（MVP）
# ------------------------------
PERF_TASK_DEFAULT_COUNT=12
PERF_TASK_MIN_COUNT=3
PERF_TASK_MAX_COUNT=30
PERF_TASK_CONCURRENCY=2
PERF_TASK_RETRY_COUNT=1
PERF_TASK_POLL_INTERVAL_MS=3000

# 运行环境
NODE_ENV=development
